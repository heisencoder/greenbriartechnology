---
import { SITE } from '../consts';

interface Props {
  heading?: string;
  text?: string;
}

const {
  heading = 'Need help with your software system?',
  text = "Tell us where you're headed. We'll help get you there.",
} = Astro.props;
---

<section class="section section--dark cta">
  <div class="container cta__inner">
    <div>
      <p class="eyebrow">Start a conversation</p>
      <h2>{heading}</h2>
      <p class="lead">{text}</p>
    </div>
    <div class="cta__actions">
      <a class="btn btn--primary" href="/contact">Get in touch</a>
      <a class="btn btn--ghost" href={`mailto:${SITE.email}`}>{SITE.email}</a>
    </div>
  </div>
</section>

<style>
  .cta__inner {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 52rem) {
    .cta__inner {
      grid-template-columns: 1.6fr 1fr;
    }
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .section--dark .btn--ghost {
    color: #ece9df;
    border-color: #3a3b30;
  }

  .section--dark .btn--ghost:hover {
    color: var(--orange-bright);
    border-color: var(--orange-bright);
  }
</style>
