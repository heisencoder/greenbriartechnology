---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import CallToAction from '../components/CallToAction.astro';

// Founding members of Greenbriar Technology Group.
// NOTE: bios are short drafts — LinkedIn blocks automated access, so please
// review and expand these. To use a real portrait, replace the `photo` path
// with a committed image (see public/team/README.md). Titles intentionally
// omitted for now.
const members = [
  {
    name: 'Josef Schroeter',
    photo: '/team/josef-schroeter.svg',
    linkedin: 'https://www.linkedin.com/in/josefschroeter/',
    bio: 'Josef is a founding member of Greenbriar Technology Group, based in Boulder, Colorado, with a background in technology leadership and strategy. Full bio coming soon.',
  },
  {
    name: 'Mike Deskevich',
    photo: '/team/mike-deskevich.svg',
    linkedin: 'https://www.linkedin.com/in/michael-deskevich-2498b1279/',
    bio: 'Mike is a founding member of Greenbriar Technology Group, bringing hands-on engineering and technical depth to client work. Full bio coming soon.',
  },
  {
    name: 'Matthew Ball',
    photo: '/team/matthew-ball.svg',
    linkedin: 'https://www.linkedin.com/in/matthewvball/',
    bio: 'Matthew is a founding member of Greenbriar Technology Group — a senior software engineer with 20+ years building data and software systems, most recently large-scale ETL and data platforms. Based in Boulder, Colorado.',
  },
];
---

<Layout
  title="Team"
  description="Meet the founding members of Greenbriar Technology Group."
>
  <PageHeader
    eyebrow="Team"
    title="The people behind Greenbriar."
    lead="A small, senior team that does the work — not just sells it. Meet the founding members."
  />

  <section class="section">
    <div class="container">
      <ul class="team-grid">
        {
          members.map((m) => (
            <li class="member card">
              <img
                class="member__photo"
                src={m.photo}
                width="600"
                height="600"
                alt={`Portrait of ${m.name}`}
                loading="lazy"
                decoding="async"
              />
              <h2 class="member__name">{m.name}</h2>
              <p class="member__bio">{m.bio}</p>
              <a
                class="member__link"
                href={m.linkedin}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="prompt">&gt;</span> LinkedIn
                <span class="member__link-host">/in</span>
              </a>
            </li>
          ))
        }
      </ul>

      <p class="note">
        <span class="prompt">#</span> Draft bios and placeholder portraits — real
        photos and full bios coming soon.
      </p>
    </div>
  </section>

  <CallToAction
    heading="Want to work with this team?"
    text="We keep the team small on purpose. Tell us about your project and we'll see if we're a fit."
  />
</Layout>

<style>
  .team-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--gap);
  }

  @media (min-width: 48rem) {
    .team-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .member {
    display: flex;
    flex-direction: column;
  }

  .member__photo {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--rule);
    margin-bottom: 1.1rem;
    background: var(--ink-dark-surface);
  }

  .member__name {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .member__bio {
    color: var(--ink-soft);
    font-size: 0.95rem;
    flex: 1;
  }

  .member__link {
    align-self: start;
    margin-top: 0.5rem;
    font-weight: 700;
    font-size: 0.95rem;
    border-bottom: 1px solid transparent;
  }

  .member__link .prompt {
    color: var(--orange);
  }

  .member__link-host {
    color: var(--ink-faint);
    font-weight: 400;
  }

  .member__link:hover .member__link-host {
    color: inherit;
  }

  .note {
    color: var(--ink-faint);
    font-size: 0.9rem;
    margin-top: 2rem;
  }

  .note .prompt,
  .member__link .prompt {
    font-weight: 700;
  }
</style>
